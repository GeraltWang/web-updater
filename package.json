{
  "name": "@ex-web-tools/web-updater",
  "version": "1.0.1",
  "description": "Detect frontend app updates by polling your entry HTML from a browser worker.",
  "homepage": "https://github.com/GeraltWang/web-updater#readme",
  "bugs": {
    "url": "https://github.com/GeraltWang/web-updater/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GeraltWang/web-updater.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm test && pnpm format:check && pnpm build"
  },
  "devDependencies": {
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
